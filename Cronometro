using  System;
using System.Threading;

namespace Cronometro
{
    class Programa
    {
        static void Main(string[] args)
        {
            Menu();
        }
        static void Menu()
        {
            Console.Clear();
            Console.WriteLine("Quantos segundos ou minutos deseja contar ?");
            Console.WriteLine("s = segundos");
            Console.WriteLine("m = minutos");
            Console.WriteLine("0 = sair");
            Console.WriteLine("");
            string dado = Console.ReadLine().ToLower();
            char tipo = char.Parse(dado.Substring(dado.Length-1, 1));
            int tempo = int.Parse(dado.Substring(0, dado.Length-1));
            int multiplicador = 1;
            if(tipo == 'm')
            {
                multiplicador = 60;
            }
            if(tempo == 0)
            {
                System.Environment.Exit(0);
            }
            Start(tempo * multiplicador);
        }
        static void Start(int tempo)
        {
            int tempoAtual = 0;
            while(tempoAtual != tempo)
            {
                Console.Clear();
                tempoAtual+=1;
                Console.WriteLine(tempoAtual);
                Thread.Sleep(1000);
            }
            Console.Clear();
            Console.WriteLine("Cronômetro finalizado.");
            Thread.Sleep(2000);
            Menu();
        }
    }
}
